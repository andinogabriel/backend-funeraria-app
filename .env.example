POSTGRES_DB=funerariadb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
SERVER_PORT=8081

JWT_TOKEN_SECRET=local-dev-jwt-secret-change-me
SECURITY_PASSWORD_PEPPER=local-dev-pepper
SECURITY_REQUEST_FINGERPRINT_SECRET=local-dev-fingerprint-secret

APP_BOOTSTRAP_ADMIN_ENABLED=true
APP_BOOTSTRAP_ADMIN_EMAIL=admin@funeraria.local
APP_BOOTSTRAP_ADMIN_PASSWORD=Admin123!
APP_BOOTSTRAP_ADMIN_FIRST_NAME=Admin
APP_BOOTSTRAP_ADMIN_LAST_NAME=Funeraria

APP_STORAGE_LOCAL_PUBLIC_BASE_URL=http://localhost:8081/files/
APP_STORAGE_PROVIDER=local
APP_STORAGE_LOCAL_ROOT_PATH=/data/storage

PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
ALERTMANAGER_PORT=9093
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Distributed tracing. Uncomment MANAGEMENT_OTLP_TRACING_ENDPOINT (or set it in your shell)
# when running with `docker compose --profile observability up` to ship spans through the local
# OTel Collector to Tempo. With it unset the application produces spans in process and the
# traceId still flows into MDC and response headers without any external dependency.
# MANAGEMENT_OTLP_TRACING_ENDPOINT=http://otel-collector:4318/v1/traces
# MANAGEMENT_TRACING_SAMPLING_PROBABILITY=1.0
OTEL_COLLECTOR_HTTP_PORT=4318
OTEL_COLLECTOR_GRPC_PORT=4317
TEMPO_HTTP_PORT=3200
