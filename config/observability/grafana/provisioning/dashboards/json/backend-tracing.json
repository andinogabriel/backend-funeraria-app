{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "HTTP latency quantiles, throughput by status, slow-route ranking and recent error traces. The latency and throughput panels read from Prometheus 'http_server_requests_seconds' histograms (auto-instrumented by Spring tracing). The Recent Error Traces panel reads from Tempo over OTLP. For ad-hoc trace lookup by traceId, use Grafana → Explore → Tempo → Search; the traceId comes from response header 'X-Trace-Id' or the structured log MDC slot.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_requests_seconds_bucket{job=\"$job\"}[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket{job=\"$job\"}[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_requests_seconds_bucket{job=\"$job\"}[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "title": "HTTP latency quantiles (p50 / p95 / p99)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 2
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (status) (rate(http_server_requests_seconds_count{job=\"$job\"}[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "title": "Throughput by status",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 4
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (uri) (rate(http_server_requests_seconds_count{job=\"$job\",status=~\"5..\"}[5m])) / clamp_min(sum by (uri) (rate(http_server_requests_seconds_count{job=\"$job\"}[5m])), 1)",
          "legendFormat": "{{uri}}",
          "refId": "A"
        }
      ],
      "title": "5xx error ratio by route",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "options": {
        "footer": { "show": false },
        "showHeader": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "topk(10, histogram_quantile(0.95, sum by (uri, le) (rate(http_server_requests_seconds_bucket{job=\"$job\"}[5m]))))",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "A"
        }
      ],
      "title": "Top 10 slowest routes (p95)",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": { "Value": "p95 latency", "uri": "route" }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "id": 5,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "queryType": "traceqlSearch",
          "filters": [
            {
              "id": "service-name",
              "tag": "service.name",
              "operator": "=",
              "scope": "resource",
              "value": ["$service"],
              "valueType": "string"
            },
            {
              "id": "status",
              "tag": "status",
              "operator": "=",
              "scope": "intrinsic",
              "value": ["error"],
              "valueType": "keyword"
            }
          ],
          "limit": 50,
          "tableType": "traces",
          "refId": "A"
        }
      ],
      "title": "Recent error traces",
      "type": "table"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["backend", "tracing", "tempo"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "backend-funeraria-app", "value": "backend-funeraria-app" },
        "hide": 0,
