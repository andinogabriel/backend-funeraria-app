        "label": "service",
        "name": "service",
        "options": [],
        "query": "backend-funeraria-app",
        "skipUrlSync": false,
        "type": "constant"
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timezone": "",
